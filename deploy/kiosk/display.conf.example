# CaptureOS display layout (optional).
# Copy to /etc/captureos/display.conf or ~/.config/captureos/display.conf
# and adjust after running:  captureos-launch.sh --list-displays
#
# CaptureOS applies this automatically on every boot.
#
# === Default (recommended): leave the lines below COMMENTED ===
# Auto-assign does the right thing without knowing resolutions:
#   * DSI/DPI panel -> booth (customer touchscreen), any resolution
#   * otherwise the smallest HDMI panel -> booth
#   * largest remaining panel -> gallery (wall TV)
#
# === Optional: pin by RESOLUTION (only if auto is wrong) ===
# Use the sizes from --list-displays for YOUR screens, e.g.:
# CAPTUREOS_BOOTH_MODE=800x480
# CAPTUREOS_GALLERY_MODE=1920x1080
#
# === Fragile: pin by connector name ===
# HDMI-A-1 / HDMI-A-2 are physical Pi ports (not "touchscreen"/"TV").
# DSI panels appear as DSI-1. Prefer auto or *_MODE over these.
# CAPTUREOS_BOOTH_OUTPUT=DSI-1
# CAPTUREOS_GALLERY_OUTPUT=HDMI-A-1
#
# Or assign by pixel geometry (x,y,width,height):
# CAPTUREOS_BOOTH_GEOM=1920,0,800,480
# CAPTUREOS_GALLERY_GEOM=0,0,1920,1080
#
# Touch mapping (if auto-detect picks the wrong device):
# CAPTUREOS_TOUCH_DEVICE="QDtech MPI7003"
# CAPTUREOS_TOUCH_LIBINPUT="QDtech MPI7003 (USB 1-1)"
#
# Touchscreen mode: multitouch (no) works with the dual-screen kiosk.
# CAPTUREOS_TOUCH_MOUSE_EMULATION=no
#
# CAPTUREOS_MANAGE_KANSHI=1
# CAPTUREOS_MANAGE_LABWC_TOUCH=1
